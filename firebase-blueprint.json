{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A supplement product in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the product" },
        "description": { "type": "string", "description": "Detailed description" },
        "price": { "type": "number", "description": "Price in USD" },
        "categories": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "Categories (e.g., Skin Care, Herbs)" 
        },
        "image": { "type": "string", "description": "URL to the product image" },
        "rating": { "type": "number", "description": "Average rating (1-5)" },
        "reviewsCount": { "type": "integer", "description": "Number of reviews" },
        "stock": { "type": "integer", "description": "Available stock" },
        "suggestedUsage": { "type": "string", "description": "Suggested usage instructions" },
        "caution": { "type": "string", "description": "Caution and warnings" },
        "supplementFacts": { "type": "string", "description": "Supplement facts and ingredients" }
      },
      "required": ["name", "price", "categories", "image"]
    },
    "Review": {
      "title": "Review",
      "description": "A user review for a product",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "ID of the product being reviewed" },
        "userId": { "type": "string", "description": "ID of the user who wrote the review" },
        "userName": { "type": "string", "description": "Name of the reviewer" },
        "rating": { "type": "number", "description": "Rating (1-5)" },
        "comment": { "type": "string", "description": "Review text" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the review was created" }
      },
      "required": ["productId", "userId", "rating", "comment"]
    },
    "ContactMessage": {
      "title": "Contact Message",
      "description": "A message from the contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the sender" },
        "email": { "type": "string", "format": "email", "description": "Email of the sender" },
        "message": { "type": "string", "description": "The message content" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was sent" }
      },
      "required": ["name", "email", "message"]
    },
    "Blog": {
      "title": "Blog",
      "description": "A blog post or information article",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Heading of the blog post" },
        "excerpt": { "type": "string", "description": "Short summary for the widget" },
        "content": { "type": "string", "description": "Full article content (Markdown supported)" },
        "category": { "type": "string", "description": "Category (e.g., Nutrition, Wellness)" },
        "image": { "type": "string", "description": "URL to the cover image" },
        "date": { "type": "string", "format": "date", "description": "Display date" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["title", "excerpt", "content", "category", "image"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of supplement products"
    },
    "/products/{productId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Reviews for a specific product"
    },
    "/contactMessages/{messageId}": {
      "schema": "ContactMessage",
      "description": "Messages received from the contact form"
    },
    "/blogs/{blogId}": {
      "schema": "Blog",
      "description": "Information and blog articles"
    }
  }
}
